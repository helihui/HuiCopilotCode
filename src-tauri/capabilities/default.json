{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Claude Code 安装器的主窗口权限配置",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "powershell",
          "cmd": "powershell",
          "args": true
        },
        {
          "name": "sh",
          "cmd": "sh",
          "args": true
        },
        {
          "name": "cmd",
          "cmd": "cmd",
          "args": true
        },
        {
          "name": "winget",
          "cmd": "winget",
          "args": true
        },
        {
          "name": "brew",
          "cmd": "brew",
          "args": true
        },
        {
          "name": "npm",
          "cmd": "npm",
          "args": true
        }
      ]
    }
  ]
}
